#~ msgid ""
#~ "Great news! You now have access to our server's media collection. Let's "
#~ "make sure you know how to use\n"
#~ "        it with Plex."
#~ msgstr ""
#~ "Gode nyheder! Du har nu adgang til vores servers mediesamling. Lad os "
#~ "sørge for, at du ved, hvordan du skal bruge\n"
#~ "        den med Plex."

#~ msgid ""
#~ "Planning on watching Movies on this device? Download Plex for this device."
